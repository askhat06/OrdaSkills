# Copy this file to docker-compose.env and fill in the real values before
# running: docker compose --env-file docker-compose.env up --build

APP_HOST_PORT=7777
POSTGRES_HOST_PORT=5432
POSTGRES_DB=elearning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms256m -Xmx512m

# Generate a real base64 secret before using this outside local testing.
APP_SECURITY_JWT_SECRET=replace-with-a-base64-encoded-jwt-secret

# Comma-separated browser origins allowed to call the backend.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# External S3-compatible video storage.
APP_MEDIA_VIDEO_BUCKET=elearning-videos
APP_MEDIA_VIDEO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
APP_MEDIA_VIDEO_PUBLIC_BASE_URL=https://media.example.com
APP_MEDIA_VIDEO_ACCESS_KEY=replace-me
APP_MEDIA_VIDEO_SECRET_KEY=replace-me
APP_MEDIA_VIDEO_REGION=auto
APP_MEDIA_VIDEO_PATH_STYLE_ACCESS_ENABLED=true
APP_MEDIA_VIDEO_PRESIGN_DURATION=15m
