# Backend runtime variables for postgres/prod profiles.
# Local demo mode (default profile) does not require these values.
# Copy this file to .env and fill in real values before running docker-compose.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_URL=jdbc:postgresql://localhost:5432/elearning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
APP_SECURITY_JWT_SECRET=replace-with-a-base64-encoded-jwt-secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
APP_CORS_ALLOWED_ORIGINS=https://yourfrontend.com

# ── S3-compatible video storage ────────────────────────────────────────────────
APP_MEDIA_VIDEO_BUCKET=elearning-videos
# Internal API endpoint (e.g. http://minio:9000 for docker-compose, or real AWS endpoint)
APP_MEDIA_VIDEO_ENDPOINT=https://storage.example.com
# Public base URL used in videoUrl responses sent to clients
APP_MEDIA_VIDEO_PUBLIC_BASE_URL=https://cdn.example.com/elearning-videos
APP_MEDIA_VIDEO_ACCESS_KEY=replace-me
APP_MEDIA_VIDEO_SECRET_KEY=replace-me
APP_MEDIA_VIDEO_REGION=us-east-1
# Set to "true" for MinIO and other S3-compatible providers; "false" for real AWS S3
APP_MEDIA_VIDEO_PATH_STYLE_ACCESS_ENABLED=true

# ── Optional overrides (defaults shown) ───────────────────────────────────────
# APP_MEDIA_VIDEO_LESSON_PREFIX=lessons
# APP_MEDIA_VIDEO_MAX_FILE_SIZE_BYTES=536870912
# APP_MEDIA_VIDEO_PRESIGN_DURATION=15m
